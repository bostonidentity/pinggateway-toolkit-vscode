{
  "name": "secret-and-inline-route",
  "condition": "${request.uri.path == '/secrets'}",
  "handler": {
    "type": "Chain",
    "config": {
      "filters": [
        {
          "type": "PasswordReplaceFilter",
          "config": {
            "secret.id": "literal-secret-value-12345",
            "header": "X-Token: ${matches(attributes.token, '^api-')}",
            "fallback": "${session.user.get()}"
          }
        }
      ],
      "handler": "ClientHandler"
    }
  }
}
